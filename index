<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hesap Silme Talebi - Rezerve</title>
    <!-- Tailwind CSS (CDN) -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --primary: #6366f1; /* Indigo-500 */
            --primary-dark: #4f46e5; /* Indigo-600 */
        }
        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 100%);
            color: #f8fafc;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-center;
            margin: 0;
        }
        .glass-panel {
            background: rgba(30, 41, 59, 0.7);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        }
        .btn-gradient {
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            transition: all 0.3s ease;
        }
        .btn-gradient:hover {
            box-shadow: 0 0 20px rgba(99, 102, 241, 0.4);
            transform: translateY(-2px);
        }
        .input-field {
            background: rgba(15, 23, 42, 0.6);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: white;
            transition: all 0.3s ease;
        }
        .input-field:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.2);
        }
        .spinner { 
            border: 3px solid rgba(255,255,255,0.1); 
            border-radius: 50%; 
            border-top-color: #fff; 
            animation: spin 0.8s linear infinite; 
            width: 20px; height: 20px; 
            display: inline-block;
        }
        @keyframes spin { to { transform: rotate(360deg); } }
    </style>
</head>
<body class="p-4 sm:p-8 flex items-center justify-center">

    <div class="glass-panel w-full max-w-lg rounded-[2rem] p-8 sm:p-10 relative overflow-hidden">
        <!-- Decoration -->
        <div class="absolute -top-24 -right-24 w-48 h-48 bg-indigo-600 rounded-full mix-blend-multiply filter blur-2xl opacity-20"></div>
        <div class="absolute -bottom-24 -left-24 w-48 h-48 bg-rose-600 rounded-full mix-blend-multiply filter blur-2xl opacity-20"></div>

        <div class="relative z-10 text-center mb-10">
            <div class="w-20 h-20 bg-rose-500/10 rounded-full flex items-center justify-center mx-auto mb-6 border border-rose-500/20">
                <i class="fa-solid fa-user-xmark text-3xl text-rose-400"></i>
            </div>
            <h1 class="text-3xl font-extrabold tracking-tight mb-2">Hesap Silme Talebi</h1>
            <p class="text-slate-400 text-sm leading-relaxed">
                Rezerve uygulamasındaki hesabınızın ve tüm verilerinizin kalıcı olarak silinmesi için aşağıya uygulamaya kayıtlı olduğunuz e-posta adresinizi giriniz.
            </p>
        </div>

        <form id="deletionForm" class="relative z-10 space-y-6">
            <div>
                <label for="email" class="block text-sm font-semibold text-slate-300 mb-2 ml-1">Kayıtlı E-posta Adresiniz</label>
                <div class="relative">
                    <i class="fa-regular fa-envelope absolute left-4 top-1/2 -translate-y-1/2 text-slate-500"></i>
                    <input type="email" id="email" required class="input-field w-full pl-12 pr-4 py-4 rounded-2xl text-lg placeholder-slate-500" placeholder="ornek@mail.com">
                </div>
            </div>

            <div class="pt-2">
                <button type="submit" id="submitBtn" class="btn-gradient w-full py-4 rounded-2xl font-bold text-lg flex items-center justify-center space-x-2 text-white">
                    <span id="btnText">Talebimi İlet</span>
                    <i id="btnIcon" class="fa-solid fa-arrow-right"></i>
                    <div id="spinner" class="spinner hidden"></div>
                </button>
            </div>
        </form>

        <div id="successMessage" class="hidden relative z-10 text-center py-6">
            <div class="w-16 h-16 bg-emerald-500/10 rounded-full flex items-center justify-center mx-auto mb-4 border border-emerald-500/20">
                <i class="fa-solid fa-check text-2xl text-emerald-400"></i>
            </div>
            <h3 class="text-xl font-bold text-white mb-2">Talebiniz Alındı</h3>
            <p class="text-slate-400 text-sm">
                Hesap silme işleminiz admin ekibimize iletilmiştir. İşlemleriniz en kısa sürede tamamlanacaktır.
            </p>
        </div>

        <div id="errorMessage" class="hidden relative z-10 mt-6 p-4 bg-rose-500/10 border border-rose-500/20 rounded-xl flex items-start space-x-3 text-rose-400 text-sm">
            <i class="fa-solid fa-circle-exclamation mt-0.5"></i>
            <span id="errorText">Bir hata oluştu. Lütfen tekrar deneyiniz.</span>
        </div>
        
        <p class="relative z-10 mt-10 text-center text-xs text-slate-600 font-medium">
            Talebiniz sisteme iletildiğinde geri alınamaz. <br> &copy; 2026 Rezerve App
        </p>
    </div>

    <!-- Firebase SDKs -->
    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.8.1/firebase-app.js";
        import { getFirestore, collection, addDoc, serverTimestamp } from "https://www.gstatic.com/firebasejs/10.8.1/firebase-firestore.js";

        // Proje Firebase Ayarları
        const firebaseConfig = {
            apiKey: "AIzaSyBaBI-Pl-p702WgLvMeIKIzv0zsOVvdt4Y",
            authDomain: "rezerve-2e744.firebaseapp.com",
            projectId: "rezerve-2e744",
            storageBucket: "rezerve-2e744.firebasestorage.app",
            messagingSenderId: "202015448126",
            appId: "1:202015448126:web:4957b0fdb97f7ae9efc56f"
        };

        const app = initializeApp(firebaseConfig);
        const db = getFirestore(app);

        const form = document.getElementById('deletionForm');
        const submitBtn = document.getElementById('submitBtn');
        const btnText = document.getElementById('btnText');
        const btnIcon = document.getElementById('btnIcon');
        const spinner = document.getElementById('spinner');
        const successMessage = document.getElementById('successMessage');
        const errorMessage = document.getElementById('errorMessage');
        const errorText = document.getElementById('errorText');

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            const email = document.getElementById('email').value.trim().toLowerCase();

            // UI Loading state
            submitBtn.disabled = true;
            btnText.textContent = "Gönderiliyor...";
            btnIcon.classList.add('hidden');
            spinner.classList.remove('hidden');
            errorMessage.classList.add('hidden');

            try {
                // "deletion_requests" adında yeni bir koleksiyona kaydediyoruz
                await addDoc(collection(db, "deletion_requests"), {
                    email: email,
                    status: "pending",
                    createdAt: serverTimestamp(),
                    source: "web_form"
                });

                // Başarı durumu
                form.classList.add('hidden');
                successMessage.classList.remove('hidden');

            } catch (error) {
                console.error("Hata:", error);
                errorText.textContent = "Veritabanına ulaşılamadı. Lütfen daha sonra tekrar deneyin. (" + error.code + ")";
                errorMessage.classList.remove('hidden');
                
                // Reset buton
                submitBtn.disabled = false;
                btnText.textContent = "Talebimi İlet";
                btnIcon.classList.remove('hidden');
                spinner.classList.add('hidden');
            }
        });
    </script>
</body>
</html>
